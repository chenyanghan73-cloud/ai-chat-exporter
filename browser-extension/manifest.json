{
  "manifest_version": 3,
  "name": "AI Chat Exporter",
  "version": "0.1.0",
  "description": "在 ChatGPT / Claude 页面抓取当前会话，并导出为 PDF、Markdown 或 JSON。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "AI Chat Exporter",
    "default_popup": "popup.html"
  }
}
